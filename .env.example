# ─────────────────────────────────────────────────────────────
# Clutch — environment variables
# Copy to `.env.local` (gitignored) and fill in. Never commit secrets.
# ─────────────────────────────────────────────────────────────

# Gemini — server-side ONLY (never expose to the client).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Calendar OAuth (client-side via Google Identity Services).
# Web-app OAuth client ID from Google Cloud → Credentials.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# PostgreSQL (Supabase / Render). DATABASE_URL is the pooled connection used at
# runtime; DIRECT_URL is the direct (non-pooled) connection used for migrations.
DATABASE_URL=
DIRECT_URL=

# Clerk auth (OPTIONAL). Auth turns on automatically only when BOTH keys below
# are set; leave them blank for the no-auth local-dev path (tasks are global).
# When set: tasks are scoped per signed-in user and "/" redirects to /sign-in.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Keep Clerk's flows in-app (so it uses our themed /sign-in screen).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
