# ─────────────────────────────────────────────────────────────
# Clutch — environment variables
# Copy to `.env.local` (gitignored) and fill in. Never commit secrets.
# ─────────────────────────────────────────────────────────────

# Gemini — server-side ONLY (never expose to the client).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Calendar OAuth (client-side via Google Identity Services).
# Web-app OAuth client ID from Google Cloud → Credentials.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# PostgreSQL (Supabase / Render). DATABASE_URL is the pooled connection used at
# runtime; DIRECT_URL is the direct (non-pooled) connection used for migrations.
DATABASE_URL=
DIRECT_URL=

# Clerk auth (optional — keep behind a flag; the app runs without it for local dev).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
